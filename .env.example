# Neon Postgres connection string. Use the pooled connection URL from the
# Neon dashboard so it works with @neondatabase/serverless (HTTP driver).
DATABASE_URL=

# Auth.js / GitHub OAuth provider credentials.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Random 32+ byte secret used by Auth.js to sign session JWTs/cookies.
AUTH_SECRET=

# Numeric GitHub user id (NOT username) of the only account allowed to sign in.
ALLOWED_GITHUB_ID=

# Google OAuth client for the Gmail-based email ingest poller.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Long-lived refresh token Lucas granted to the email-ingest worker.
GOOGLE_REFRESH_TOKEN=

# Random 32+ byte secret used to authenticate Vercel cron pings. Vercel
# automatically sends `Authorization: Bearer ${CRON_SECRET}` to scheduled
# routes when this is set in the project env. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
